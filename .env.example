# Application URL (e.g., https://your-app.onrender.com)
APP_URL=

# Flutterwave API Keys
FLW_SECRET_KEY=
FLW_PUBLIC_KEY=

# Flutterwave Webhook Secret Hash (Set this in Flutterwave Dashboard)
FLW_SECRET_HASH=

# Admin Password (Optional, defaults to 'admin')
ADMIN_PASSWORD=

# Session Secret (Optional)
SESSION_SECRET=
