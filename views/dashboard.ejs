<div class="max-w-6xl mx-auto">
    <header class="mb-8">
        <h2 class="text-3xl font-bold">Dashboard Overview</h2>
        <p class="text-slate-400">Welcome back, Admin.</p>
    </header>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <div class="glass p-6 rounded-2xl">
            <div class="text-slate-400 text-sm mb-1">Total Extensions</div>
            <div class="text-4xl font-bold"><%= stats.extensionsCount %></div>
        </div>
        <div class="glass p-6 rounded-2xl">
            <div class="text-slate-400 text-sm mb-1">Total Revenue</div>
            <div class="text-4xl font-bold text-green-400">$<%= stats.totalRevenue.toFixed(2) %></div>
        </div>
        <div class="glass p-6 rounded-2xl">
            <div class="text-slate-400 text-sm mb-1">Active Licenses</div>
            <div class="text-4xl font-bold text-blue-400"><%= stats.activeLicenses %></div>
        </div>
    </div>

    <!-- Recent Activity -->
    <div class="glass rounded-2xl overflow-hidden">
        <div class="p-6 border-b border-slate-800 flex justify-between items-center">
            <h3 class="text-xl font-semibold">Recent Payments</h3>
            <a href="/extensions" class="text-blue-400 text-sm hover:underline">View All</a>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead class="bg-slate-900/50 text-slate-400 text-sm">
                    <tr>
                        <th class="px-6 py-4 font-medium">Transaction ID</th>
                        <th class="px-6 py-4 font-medium">Amount</th>
                        <th class="px-6 py-4 font-medium">Status</th>
                        <th class="px-6 py-4 font-medium">Date</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-800">
                    <% if (stats.recentPayments.length === 0) { %>
                        <tr>
                            <td colspan="4" class="px-6 py-8 text-center text-slate-500">No recent payments found.</td>
                        </tr>
                    <% } %>
                    <% stats.recentPayments.forEach(payment => { %>
                        <tr class="hover:bg-slate-900/30 transition-colors">
                            <td class="px-6 py-4 font-mono text-sm"><%= payment.flw_transaction_id %></td>
                            <td class="px-6 py-4 font-semibold"><%= payment.currency %> <%= payment.amount %></td>
                            <td class="px-6 py-4">
                                <span class="px-2 py-1 rounded-full text-xs font-medium <%= payment.status === 'successful' ? 'bg-green-500/10 text-green-400' : 'bg-yellow-500/10 text-yellow-400' %>">
                                    <%= payment.status %>
                                </span>
                            </td>
                            <td class="px-6 py-4 text-slate-400 text-sm">
                                <%= new Date(payment.paid_at).toLocaleDateString() %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>
