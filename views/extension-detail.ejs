<div class="max-w-6xl mx-auto">
    <nav class="mb-8 text-sm">
        <a href="/extensions" class="text-slate-400 hover:text-white">← Back to Extensions</a>
    </nav>

    <header class="mb-12 flex items-start justify-between">
        <div class="flex items-center">
            <div class="w-20 h-20 bg-slate-800 rounded-2xl flex items-center justify-center text-4xl mr-6 overflow-hidden">
                <% if (extension.icon_url) { %>
                    <img src="<%= extension.icon_url %>" alt="<%= extension.name %>" class="w-full h-full object-cover">
                <% } else { %>
                    🧩
                <% } %>
            </div>
            <div>
                <h2 class="text-4xl font-bold mb-2"><%= extension.name %></h2>
                <p class="text-slate-400 max-w-xl"><%= extension.description %></p>
                <div class="mt-4 flex space-x-4">
                    <span class="bg-slate-800 px-3 py-1 rounded-full text-xs font-mono text-slate-300">Slug: <%= extension.slug %></span>
                    <span class="bg-slate-800 px-3 py-1 rounded-full text-xs text-slate-300">Created: <%= new Date(extension.created_at).toLocaleDateString() %></span>
                </div>
            </div>
        </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Plans Section -->
        <div class="lg:col-span-1 space-y-6">
            <div class="glass p-6 rounded-2xl">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-xl font-semibold">Pricing Plans</h3>
                    <button onclick="document.getElementById('add-plan-modal').classList.remove('hidden')" class="text-blue-400 text-sm hover:underline">+ Add</button>
                </div>
                <div class="space-y-4">
                    <% if (plans.length === 0) { %>
                        <p class="text-slate-500 text-sm italic">No plans created yet.</p>
                    <% } %>
                    <% plans.forEach(plan => { %>
                        <div class="bg-slate-900/50 border border-slate-800 p-4 rounded-xl flex justify-between items-center">
                            <div>
                                <div class="font-bold"><%= plan.name %></div>
                                <div class="text-xs text-slate-400 uppercase tracking-wider"><%= plan.type %> • <%= plan.currency %> <%= plan.price %></div>
                            </div>
                            <form action="/api/plans/<%= plan.id %>/delete" method="POST" onsubmit="return confirm('Delete this plan?')">
                                <button type="submit" class="text-slate-500 hover:text-red-400 transition-colors text-sm">Remove</button>
                            </form>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>

        <!-- Licenses Section -->
        <div class="lg:col-span-2">
            <div class="glass rounded-2xl overflow-hidden">
                <div class="p-6 border-b border-slate-800">
                    <h3 class="text-xl font-semibold">Recent Licenses</h3>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead class="bg-slate-900/50 text-slate-400 text-sm">
                            <tr>
                                <th class="px-6 py-4 font-medium">Customer</th>
                                <th class="px-6 py-4 font-medium">License Key</th>
                                <th class="px-6 py-4 font-medium">Status</th>
                                <th class="px-6 py-4 font-medium">Expires</th>
                                <th class="px-6 py-4 font-medium">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-800">
                            <% if (licenses.length === 0) { %>
                                <tr>
                                    <td colspan="5" class="px-6 py-8 text-center text-slate-500">No licenses issued yet.</td>
                                </tr>
                            <% } %>
                            <% licenses.forEach(license => { %>
                                <tr class="hover:bg-slate-900/30 transition-colors">
                                    <td class="px-6 py-4 text-sm"><%= license.customer_email %></td>
                                    <td class="px-6 py-4 font-mono text-xs"><%= license.license_key %></td>
                                    <td class="px-6 py-4">
                                        <span class="px-2 py-1 rounded-full text-xs font-medium <%= license.status === 'active' ? 'bg-green-500/10 text-green-400' : 'bg-red-500/10 text-red-400' %>">
                                            <%= license.status %>
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 text-slate-400 text-xs">
                                        <%= license.expires_at ? new Date(license.expires_at).toLocaleDateString() : 'Lifetime' %>
                                    </td>
                                    <td class="px-6 py-4">
                                        <% if (license.status === 'active') { %>
                                            <form action="/api/licenses/<%= license.id %>/revoke" method="POST" onsubmit="return confirm('Revoke this license?')">
                                                <button type="submit" class="text-red-400 text-xs hover:underline">Revoke</button>
                                            </form>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Add Plan Modal -->
    <div id="add-plan-modal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center p-4 z-50">
        <div class="bg-slate-900 border border-slate-800 w-full max-w-md rounded-2xl p-8 shadow-2xl">
            <h3 class="text-2xl font-bold mb-6">Add Pricing Plan</h3>
            <form action="/api/extensions/<%= extension.id %>/plans" method="POST" class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-slate-400 mb-1">Plan Name</label>
                    <input type="text" name="name" required class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Basic Monthly, Pro Lifetime, etc.">
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-400 mb-1">Type</label>
                    <select name="type" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
                        <option value="one_time">One-Time Payment</option>
                        <option value="monthly">Monthly Subscription</option>
                        <option value="yearly">Yearly Subscription</option>
                    </select>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-slate-400 mb-1">Price</label>
                        <input type="number" step="0.01" name="price" required class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-400 mb-1">Currency</label>
                        <input type="text" name="currency" value="USD" required class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
                    </div>
                </div>
                <div class="flex space-x-4 mt-8">
                    <button type="button" onclick="document.getElementById('add-plan-modal').classList.add('hidden')" class="flex-1 bg-slate-800 hover:bg-slate-700 py-2 rounded-lg font-medium">Cancel</button>
                    <button type="submit" class="flex-1 bg-blue-600 hover:bg-blue-700 py-2 rounded-lg font-bold">Add Plan</button>
                </div>
            </form>
        </div>
    </div>
</div>
