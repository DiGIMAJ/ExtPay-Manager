<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ExtPay Manager - Monetize Your Chrome Extensions</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Anton&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-slate-950: #020617;
            --bg-slate-900: #0f172a;
            --text-slate-200: #e2e8f0;
            --text-slate-400: #94a3b8;
            --blue-600: #2563eb;
            --blue-700: #1d4ed8;
        }
        body { 
            font-family: 'Inter', sans-serif; 
            background-color: var(--bg-slate-950); 
            color: var(--text-slate-200);
            margin: 0;
        }
        .font-display { font-family: 'Anton', sans-serif; }
        .glass {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
        @keyframes float {
            0% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-20px) rotate(2deg); }
            100% { transform: translateY(0px) rotate(0deg); }
        }
        .float { animation: float 6s ease-in-out infinite; }
    </style>
</head>
<body class="bg-slate-950 text-slate-200 overflow-x-hidden">
    <!-- Navigation -->
    <nav class="fixed top-0 w-full z-50 glass border-b border-slate-800/50 px-6 py-4 flex justify-between items-center">
        <div class="text-xl font-bold bg-gradient-to-r from-blue-400 to-indigo-400 bg-clip-text text-transparent">
            ExtPay Manager
        </div>
        <a href="/dashboard" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-full font-semibold transition-all shadow-lg shadow-blue-900/20">
            Go to Dashboard
        </a>
    </nav>

    <!-- Hero Section -->
    <main class="min-h-screen flex flex-col items-center justify-center pt-20 px-6 text-center relative">
        <!-- Decorative Elements -->
        <div class="absolute top-1/4 left-1/4 w-64 h-64 bg-blue-600/10 rounded-full blur-[120px] -z-10"></div>
        <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-indigo-600/10 rounded-full blur-[150px] -z-10"></div>

        <div class="max-w-5xl mx-auto">
            <h1 class="font-display text-7xl md:text-9xl uppercase leading-[0.85] tracking-tighter mb-8">
                Monetize <br>
                <span class="text-blue-500">Extensions</span> <br>
                Instantly
            </h1>
            
            <p class="text-xl md:text-2xl text-slate-400 max-w-2xl mx-auto mb-12 leading-relaxed">
                A self-hosted payment manager for Chrome Extension developers. 
                Integrate Flutterwave, manage licenses, and track revenue from one dashboard.
            </p>

            <div class="flex flex-col md:flex-row gap-6 justify-center items-center">
                <div class="glass p-8 rounded-3xl text-left max-w-sm float">
                    <div class="text-blue-400 text-3xl mb-4">🧩</div>
                    <h3 class="text-xl font-bold mb-2 text-white">Multi-Extension</h3>
                    <p class="text-slate-400 text-sm">Manage multiple extensions and pricing plans from a single interface.</p>
                </div>
                <div class="glass p-8 rounded-3xl text-left max-w-sm float" style="animation-delay: -2s">
                    <div class="text-indigo-400 text-3xl mb-4">💳</div>
                    <h3 class="text-xl font-bold mb-2 text-white">Flutterwave Ready</h3>
                    <p class="text-slate-400 text-sm">Built-in integration with Flutterwave for global payments and webhooks.</p>
                </div>
                <div class="glass p-8 rounded-3xl text-left max-w-sm float" style="animation-delay: -4s">
                    <div class="text-emerald-400 text-3xl mb-4">🛡️</div>
                    <h3 class="text-xl font-bold mb-2 text-white">License API</h3>
                    <p class="text-slate-400 text-sm">Simple REST API to verify licenses directly from your background scripts.</p>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="py-12 border-t border-slate-900 text-center text-slate-500 text-sm">
        <p>&copy; 2026 ExtPay Manager. Built for Extension Developers.</p>
    </footer>
</body>
</html>
